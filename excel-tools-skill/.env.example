# Excel Tools Skill Environment Variables
# Copy this file to .env and set your values

# Required for token generation/validation
EXCEL_AGENT_SECRET=your-256-bit-hex-secret-key-here

# Optional: LibreOffice path (auto-detected if not set)
# LIBREOFFICE_PATH=/usr/bin/soffice

# Optional: Default output directory
# EXCEL_OUTPUT_DIR=./output
