{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "excel-agent-tools/schemas/write_data",
  "title": "Write Data Schema",
  "description": "Validates cell data arrays for write operations",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "description": "2D array of cell values",
      "items": {
        "type": "array",
        "items": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        }
      }
    }
  },
  "required": ["data"]
}
