{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "excel-agent-tools/schemas/token_request",
  "title": "Token Request Schema",
  "description": "Validates token generation request structure",
  "type": "object",
  "properties": {
    "scope": {
      "type": "string",
      "description": "Token scope for operation approval",
      "enum": [
        "sheet:delete",
        "sheet:rename",
        "range:delete",
        "formula:convert",
        "macro:remove",
        "macro:inject",
        "structure:modify"
      ]
    },
    "target_file": {
      "type": "string",
      "description": "Path to the target workbook"
    },
    "ttl_seconds": {
      "type": "integer",
      "description": "Token time-to-live in seconds",
      "minimum": 1,
      "maximum": 3600,
      "default": 300
    }
  },
  "required": ["scope", "target_file"]
}
